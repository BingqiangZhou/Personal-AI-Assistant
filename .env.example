# Application
APP_NAME=PodDigest
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/poddigest

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Security - Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Whisper
WHISPER_MODEL=whisper-1
OPENAI_API_KEY=

# External APIs
XYZRANK_API_URL=https://xyzrank.com/api/podcasts

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Docker PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=poddigest

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
